				"body": {
					"mode": "raw",
					"raw": "{\n  \"username\": \"Sinh Vien A\",\n  \"email\": \"sv.a@gmail.com\",\n  \"password\": \"123456\",\n  \"roleName\": \"SINHVIEN\"\n}"
