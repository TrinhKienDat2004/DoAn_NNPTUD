		},
		{
			"name": "2. Đăng nhập (Login)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 200 || pm.response.code === 201) {",
							"    var jsonData = pm.response.json();",
							"    pm.environment.set(\"token\", jsonData.data.token);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"sv.a@gmail.com\",\n  \"password\": \"123456\"\n}"
				},
				"url": {
					"raw": "http://localhost:3000/api/v1/auth/login",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "3000",
					"path": [
						"api",
						"v1",
						"auth",
						"login"
					]
				}
			},
			"response": []
		},
		{
			"name": "3. Đổi mật khẩu",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"oldPassword\": \"123456\",\n  \"newPassword\": \"matkhaumoi!\"\n}"
				},
				"url": {
					"raw": "http://localhost:3000/api/v1/auth/change-password",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "3000",
					"path": [
						"api",
						"v1",
						"auth",
						"change-password"
					]
				}
			},
			"response": []
		}
